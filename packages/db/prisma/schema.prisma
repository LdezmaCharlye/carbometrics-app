generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SuperAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("super_admins")
}

model Company {
  id               String      @id @default(cuid())
  name             String
  taxId            String      @unique
  industry         String
  country          String      @default("BO")
  orgBoundaryType    OrgBoundaryType @default(OPERATIONAL_CONTROL)
  baseYear           Int?
  baseYearRecalcNote String?
  isActive         Boolean     @default(true)
  reportingYear    Int         @default(2024)
  yearFrom         Int         @default(2020)
  yearTo           Int         @default(2030)
  licenseType      LicenseType @default(BASIC)
  licenseExpiresAt DateTime?
  maxUsers         Int         @default(2)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  branches        Branch[]
  users           User[]
  emissionSources EmissionSource[]
  ghgInventories  GhgInventory[]

  @@map("companies")
}

enum LicenseType {
  BASIC
  STANDARD
  ENTERPRISE
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  address   String?
  city      String?
  country   String   @default("BO")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId       String
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  emissionSources EmissionSource[]
  consumptionLogs ConsumptionLog[]
  users           User[]

  @@map("branches")
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String
  passwordHash       String
  role               UserRole  @default(VIEWER)
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  companyId       String
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId        String?
  branch          Branch?          @relation(fields: [branchId], references: [id])
  consumptionLogs         ConsumptionLog[] @relation("RecordedBy")
  verifiedConsumptionLogs ConsumptionLog[] @relation("VerifiedBy")

  @@map("users")
}

enum UserRole {
  MANAGER
  VIEWER
}

model EmissionSource {
  id          String           @id @default(cuid())
  name        String
  description String?
  assetCode   String?
  scope       EmissionScope
  category    EmissionCategory
  unit        MeasurementUnit
  isActive          Boolean          @default(true)
  uncertaintyLevel  UncertaintyLevel @default(MEDIUM)
  uncertaintyNote   String?
  isExcluded        Boolean          @default(false)
  exclusionReason   String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  companyId        String
  company          Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId         String?
  branch           Branch?         @relation(fields: [branchId], references: [id])
  emissionFactorId String?
  emissionFactor   EmissionFactor? @relation(fields: [emissionFactorId], references: [id])
  consumptionLogs  ConsumptionLog[]

  @@map("emission_sources")
}

enum UncertaintyLevel {
  LOW
  MEDIUM
  HIGH
}

enum EmissionScope {
  SCOPE_1
  SCOPE_2
  SCOPE_3
}

enum EmissionCategory {
  STATIONARY_COMBUSTION
  MOBILE_COMBUSTION
  PROCESS_EMISSIONS
  FUGITIVE_EMISSIONS
  PURCHASED_ELECTRICITY
  PURCHASED_HEAT
  PURCHASED_COOLING
  BUSINESS_TRAVEL
  EMPLOYEE_COMMUTING
  WASTE_DISPOSAL
  PURCHASED_GOODS
  UPSTREAM_TRANSPORT
  DOWNSTREAM_TRANSPORT
  USE_OF_SOLD_PRODUCTS
  END_OF_LIFE_TREATMENT
}

enum MeasurementUnit {
  LITER
  GALLON_US
  M3
  KG
  TON
  KWH
  MWH
  KM
  KM_PASSENGER
  TON_KM
  TON_WASTE
  USD
}

model ConsumptionLog {
  id               String   @id @default(cuid())
  year             Int
  month            Int
  quantity         Float
  emissionsKgCO2eq Float    @default(0)
  notes            String?
  dataQuality      DataQuality @default(ESTIMATED)
  isVerified       Boolean   @default(false)
  verifiedAt       DateTime?
  verificationNote String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  companyId        String
  branchId         String?
  branch           Branch?        @relation(fields: [branchId], references: [id])
  emissionSourceId String
  emissionSource   EmissionSource @relation(fields: [emissionSourceId], references: [id])
  recordedById     String
  recordedBy       User            @relation("RecordedBy", fields: [recordedById], references: [id])
  verifiedById     String?
  verifiedBy       User?           @relation("VerifiedBy", fields: [verifiedById], references: [id])
  evidenceImages   EvidenceImage[]

  @@index([companyId, year, month])
  @@index([emissionSourceId, year])
  @@map("consumption_logs")
}

model EvidenceImage {
  id               String   @id @default(cuid())
  cloudinaryId     String
  url              String
  thumbnailUrl     String?
  fileName         String
  fileSize         Int
  mimeType         String
  description      String?
  uploadedAt       DateTime @default(now())

  consumptionLogId String
  consumptionLog   ConsumptionLog @relation(fields: [consumptionLogId], references: [id], onDelete: Cascade)

  @@index([consumptionLogId])
  @@map("evidence_images")
}

model EmissionFactor {
  id        String          @id @default(cuid())
  name      String
  fuelType  String?
  unit      MeasurementUnit
  kgCO2     Float           @default(0)
  kgCH4     Float           @default(0)
  kgN2O     Float           @default(0)
  source    FactorSource
  region    String          @default("GLOBAL")
  year      Int             @default(2023)
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  emissionSources EmissionSource[]

  @@map("emission_factors")
}

enum FactorSource {
  IPCC_AR6
  DEFRA_2023
  EPA_2023
  CUSTOM
}

model GhgInventory {
  id             String          @id @default(cuid())
  reportingYear  Int
  status         InventoryStatus @default(DRAFT)
  totalScope1    Float           @default(0)
  totalScope2    Float           @default(0)
  totalScope3    Float           @default(0)
  totalEmissions Float           @default(0)
  revenueUSD     Float?
  employeeCount  Int?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, reportingYear])
  @@map("ghg_inventories")
}

enum InventoryStatus {
  DRAFT
  COMPLETE
  VERIFIED
  PUBLISHED
}
enum OrgBoundaryType {
  OPERATIONAL_CONTROL
  FINANCIAL_CONTROL
  EQUITY_SHARE
}

enum DataQuality {
  DIGITAL_INVOICE
  PHYSICAL_INVOICE
  MEASURED
  CALCULATED
  ESTIMATED
}
model CountryEmissionFactor {
  id          String   @id @default(cuid())
  countryCode String   @unique
  countryName String
  kgCO2perKwh Float
  source      String
  year        Int      @default(2023)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("country_emission_factors")
}